    <file src="E:\工具\Keyence\net-keyence-hostlink\src\Keyence.HostLink\bin\Release\net8.0\Keyence.HostLink.pdb" target="lib\net8.0\Keyence.HostLink.pdb" />
    <file src="E:\工具\Keyence\net-keyence-hostlink\src\Keyence.HostLink\bin\Release\netstandard2.0\Keyence.HostLink.pdb" target="lib\netstandard2.0\Keyence.HostLink.pdb" />
